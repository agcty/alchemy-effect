{
  "description": "Make user-like fields (anything ending in _by, plus user/owner/assigned_to/primary_account) nullable across PostHog schemas. The spec marks them as non-null $refs but the API regularly returns null when the user has been deleted, when the request was made by an anonymous/system actor, or when the field is unset. Without this patch, decoding fails on every list response that contains an entry with a deleted/system user.",
  "patches": [
    {
      "op": "add",
      "path": "/components/schemas/Action/properties/created_by/nullable",
      "value": true
    },
    {
      "op": "replace",
      "path": "/components/schemas/ActivityLog/properties/user",
      "value": {
        "allOf": [
          {
            "$ref": "#/components/schemas/UserBasic"
          }
        ],
        "nullable": true
      }
    },
