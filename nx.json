{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "tui": {
    "enabled": true,
    "autoExit": true
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "{workspaceRoot}/bun.lock"],
    "taskSources": [
      "default",
      "!{projectRoot}/**/*.md",
      "!{projectRoot}/docs/**",
      "!{projectRoot}/README.md"
    ],
    "production": [
      "taskSources",
      "!{projectRoot}/**/*.spec.*",
      "!{projectRoot}/**/*.test.*",
      "!{projectRoot}/**/__tests__/**",
      "!{projectRoot}/test/**",
      "!{projectRoot}/vitest.config.*",
      "!{projectRoot}/playwright.config.*"
    ]
  },
  "pluginsConfig": {
    "@nx/js": {
      "projectsAffectedByDependencyUpdates": "auto"
    }
  },
  "targetDefaults": [
    {
      "target": "build",
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": [
        "{projectRoot}/lib",
        "{projectRoot}/dist",
        "{projectRoot}/.cache",
        "{projectRoot}/tsconfig.tsbuildinfo"
      ],
      "cache": true
    },
    {
      "target": "typecheck",
      "dependsOn": ["^build"],
      "inputs": ["taskSources", "^production"],
      "outputs": ["{projectRoot}/.cache", "{projectRoot}/tsconfig.tsbuildinfo"],
      "cache": true
    },
    {
      "target": "test",
      "dependsOn": ["build", "^build"],
      "inputs": [
        "taskSources",
        "^production",
        {
          "env": "CI"
        }
      ],
      "outputs": [],
      "cache": true
    },
    {
      "target": "lint",
      "inputs": ["taskSources"],
      "outputs": [],
      "cache": true
    },
    {
      "target": "dev",
      "cache": false,
      "continuous": true,
      "dependsOn": ["^build"]
    },
    {
      "target": "deploy",
      "cache": false,
      "dependsOn": ["build"]
    },
    {
      "target": "destroy",
      "cache": false
    }
  ],
  "release": {
    "projects": [
      "alchemy",
      "@alchemy.run/better-auth",
      "@alchemy.run/pr-package",
      "@distilled.cloud/*"
    ],
    "projectsRelationship": "independent",
    "version": {
      "conventionalCommits": true,
      "updateDependents": "auto"
    },
    "changelog": {
      "workspaceChangelog": true,
      "projectChangelogs": true
    }
  },
  "neverConnectToCloud": true,
  "analytics": false
}
